# Gabriella — environment variable template
#
# Copy this file to .env.local and fill in the values you need. The file
# .env.local is gitignored — never commit real credentials.
#
# In production (Vercel), set these as Project Environment Variables.
# In dev, .env.local is loaded by `npm run dev` and by the CLI scripts
# that pass --env-file=.env.local.


# ─── Required ────────────────────────────────────────────────────────────────

# Groq — primary model provider for cores, synthesis, speaker, gauntlet,
# and every evaluator. One key is enough to run; more keys unlock the pool
# (see below).
GROQ_API_KEY=

# Upstash Redis — persistent memory, soul, register, threads, pending
# state, logs, learning history, episodic store. The whole psyche lives here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash Vector — resonant memory (imprints, thoughts, exchanges).
# Uses a Fastembed-enabled index so raw text is embedded server-side.
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# Bearer token shared between Vercel Cron and the /api/think, /api/sleep,
# /api/learn, /api/learn/watch endpoints. Without this the cron routes
# are open — set a value even for dev.
CRON_SECRET=


# ─── Groq multi-key pool (optional) ───────────────────────────────────────────
# Each additional Groq key unlocks a separate free-tier rate-limit budget.
# With ≥3 keys, Alpha / Beta / Gamma each get their own dedicated account
# so the triple-core runs truly in parallel. All other calls round-robin
# across the full set. Up to 10 keys supported.
#
# GROQ_API_KEY_2=
# GROQ_API_KEY_3=
# GROQ_API_KEY_4=
# ... up to GROQ_API_KEY_10=


# ─── Model tier overrides (optional) ──────────────────────────────────────────
# The defaults are already good — only override if you want to experiment.
# GABRIELLA_PREMIUM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GABRIELLA_FAST_MODEL=llama-3.1-8b-instant


# ─── Weekly learning loop — Fireworks AI (recommended) ────────────────────────
# When set, /api/learn pushes training bundles to Fireworks every Monday.
# Set AUTO_FINETUNE=1 to also auto-launch SFT jobs + activate the fine-tune
# as Gabriella's speaker when training completes.
#
# FIREWORKS_API_KEY=
# FIREWORKS_ACCOUNT_ID=
# FIREWORKS_BASE_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
# AUTO_FINETUNE=1
# AUTO_FINETUNE_MIN_EXAMPLES=50
# AUTO_FINETUNE_MIN_DAYS_BETWEEN=7


# ─── Alternative or additional learning providers (optional) ──────────────────
# Together AI — uploads same CoT bundle; no auto-finetune wiring.
# TOGETHER_API_KEY=
#
# Generic webhook — POSTs the JSONL to any URL you control.
# LEARNING_WEBHOOK_URL=
